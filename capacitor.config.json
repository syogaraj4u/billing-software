{
  "appId": "in.nirvanasolutions.billing",
  "appName": "Nirvana Billing",
  "webDir": "mobile/www",
  "backgroundColor": "#f5f7f8",
  "ios": {
    "contentInset": "automatic",
    "preferredContentMode": "mobile",
    "allowsLinkPreview": false,
    "scrollEnabled": true
  },
  "android": {
    "backgroundColor": "#f5f7f8",
    "allowMixedContent": false,
    "captureInput": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#142223",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#f5f7f8",
      "overlaysWebView": false
    },
    "Keyboard": {
      "resize": "body",
      "style": "DARK",
      "resizeOnFullScreen": true
    }
  }
}

